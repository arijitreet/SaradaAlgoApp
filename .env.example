# ── Database ────────────────────────────────────────────────
# Embedded H2 file database — created automatically at backend/data/sarada.mv.db.
# No setup needed; override only if you want a different location/credentials.
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/sarada;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# ── Zerodha Kite Connect ────────────────────────────────────
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
# Must match the redirect URL registered on developers.kite.trade
KITE_REDIRECT_URL=http://localhost:8080/api/broker/callback

# ── App security ────────────────────────────────────────────
# 256-bit base64 key for JWT signing:    openssl rand -base64 32
APP_JWT_SECRET=
# 256-bit base64 key for AES-GCM token encryption: openssl rand -base64 32
APP_CRYPTO_KEY=
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-admin

# ── Runtime ─────────────────────────────────────────────────
# paper (simulated fills) | live (real orders via Kite)
SPRING_PROFILES_ACTIVE=live
